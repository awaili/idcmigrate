# ---- idc-migrate configuration ----
# Copy to .env and edit. All values are optional — defaults let the system
# run out-of-the-box against bundled fixtures.

# Data store — MariaDB on the DB box (10.0.0.3:3306). URL-encode special
# chars in the password (e.g. '#' -> %23, '!' -> %21). The default below is
# also baked into config.py, so this line is only needed to override it.
IDC_DB_URL=mysql://idc_migrate_app:IdcMigrate%232026%21@10.0.0.3:3306/idc_migrate

# ---- Inventory sources ----
# Each source has an "online" mode (real API) and an "offline" mode (fixture).
# If the connection settings are absent/empty, the adapter loads its fixture.

# ServiceNow CMDB
IDC_SERVICENOW_BASE=            # https://example.service-now.com
IDC_SERVICENOW_USER=
IDC_SERVICENOW_PASSWORD=        # or IDC_SERVICENOW_TOKEN for token auth
IDC_SERVICENOW_TABLE=cmdb_ci_server
IDC_SERVICENOW_LIMIT=10000
IDC_SERVICENOW_PATH=./fixtures/servicenow_cmdb_ci_server.csv  # offline file (fixture default)

# RVTools (file path to exported CSV/xlsx directory or single vInfo file)
IDC_RVTOOLS_PATH=./fixtures/rvtools_vInfo.csv

# Zabbix
IDC_ZABBIX_URL=                 # http://zabbix.example.com/api_jsonrpc.php
IDC_ZABBIX_TOKEN=               # API token (Zabbix >= 5.4) or user/pw below
IDC_ZABBIX_USER=
IDC_ZABBIX_PASSWORD=
IDC_ZABBIX_PATH=./fixtures/zabbix_hosts.json   # offline file (fixture default)

# Prometheus
IDC_PROM_URL=                   # http://prometheus.example.com:9090
IDC_PROM_TIMEOUT=30
IDC_PROMETHEUS_PATH=./fixtures/prometheus_metrics.json  # offline file (fixture default)

# ---- MigraQ gateway (Ollama-compatible) ----
# This box runs a local Ollama-fronted gateway to cloud models.
IDC_LLM_BASE=http://127.0.0.1:11434
IDC_LLM_MODEL=glm-5.2:cloud
IDC_LLM_TIMEOUT=120
IDC_LLM_ENABLED=true            # set false to force rule-only / no MigraQ

# ---- Claude Code agent ----
IDC_CLAUDE_BIN=claude           # path to claude CLI
IDC_CLAUDE_TIMEOUT=600          # seconds per agent task
# Default permission mode for spawned claude tasks. "plan" = read-only/answer
# only (safe default). "execute" = allow file writes + bash (opt in via --execute).
IDC_CLAUDE_DEFAULT_MODE=plan

# ---- External agent executor (code scan / comb / modify) ----
# See docs/agent-executor.md for the full interface spec. The executor scans an
# app's source repo, combs it into a CodeProfile, and pushes results back here.
# IDC_EXECUTOR_TOKEN is the shared bearer secret for BOTH directions: it
# authorizes idc→executor requests AND validates executor→idc push callbacks.
IDC_EXECUTOR_URL=               # https://executor.example.com (empty → feature off)
IDC_EXECUTOR_TOKEN=             # shared secret; required to accept push callbacks
IDC_EXECUTOR_TIMEOUT=600        # seconds for idc→executor HTTP calls
IDC_EXECUTOR_ENABLED=true       # set false to refuse trigger requests
IDC_PUBLIC_URL=                 # THIS server's public HTTPS base (e.g. https://mig.zaymuc.com);
                                # sent as the per-request `callback` so a remote executor on the
                                # internet can push results back here. Empty → executor must set
                                # its own callback base (IDC_CALLBACK_BASE). Overridable via the
                                # Manage-executor panel.

# ---- TCO / business case (F2) ----
# Tencent Cloud pricing source. Empty -> cost.py uses a bundled price fixture
# so the business case still renders out of the box.
IDC_PRICING_URL=                # https://pricing.tencent.com/... (empty -> fixture prices)
# Optional JSON {old_sku_or_target: price} map for customer contract pricing
# (same old->new override shape as the executor overrides).
IDC_PRICING_OVERRIDE_PATH=

# ---- Migration execution runner (F6 / F6.5) ----
# Empty by default -> F6 runs in "track only" mode (operator / external tool
# performs the migration; idc-migrate records state + runs validation gates).
# Wire when Tencent SMS/DTS API access is available.
IDC_SMS_BASE=                   # https://sms.tencentcloudapi.com (empty -> track-only)
IDC_SMS_REGION=                 # ap-shanghai / ap-guangzhou / ...
IDC_SMS_TOKEN=                  # API credential

# ---- Network dependency discovery (F1) ----
# Source for runtime network-dependency edges. Standard Prometheus/Zabbix
# exporters do NOT expose per-connection dst ip:port, so the realistic primary
# source is a small agent (eBPF / conntrack / `ss` snapshot) written to the
# fixture file below.
#   collector (default) | prometheus (custom connection exporter, falls back
#   to fixture) | zabbix (custom item, falls back to fixture) | off (disabled).
IDC_NETDEP_SOURCE=collector
IDC_NETDEP_DAYS=7               # history window (days) for dependency observation
IDC_NETDEP_PATH=./fixtures/netdep.json   # agent-collected ss-tn-style snapshot